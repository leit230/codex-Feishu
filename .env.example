FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_BRIDGE_PORT=8000
FEISHU_USE_WS=true
FEISHU_MCP_AUTO_START=true
FEISHU_AUTO_START=true
FEISHU_TRIGGER_PREFIX=
FEISHU_REPLY_IN_THREAD=false
FEISHU_MAX_REPLY_CHARS=12000
FEISHU_DOWNLOAD_DIR=/home/leitao/plugins/feishu-bridge/downloads
FEISHU_MAX_INLINE_FILE_BYTES=1048576
CODEX_COMMAND=codex
CODEX_MODE=app-server
CODEX_MODEL=
CODEX_USE_SESSION=true
CODEX_SESSION_TTL_MS=3600000
CODEX_APP_SERVER_ARGS=app-server --listen stdio://
CODEX_ARGS=exec --json --dangerously-bypass-approvals-and-sandbox --skip-git-repo-check --ignore-rules
CODEX_CWD=/home/leitao
CODEX_OUTPUT_DIRS=/home/leitao /home/leitao/plugins/feishu-bridge/outputs
CODEX_TIMEOUT_MS=300000
